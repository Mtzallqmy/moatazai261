# Public Supabase configuration. Safe for the browser when RLS is enabled.
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
NEXT_PUBLIC_SITE_URL=https://moatazalalqami.online

# Server-only Supabase secret. Configure only in the hosting environment.
SUPABASE_SECRET_KEY=
# Legacy fallback only; prefer SUPABASE_SECRET_KEY for new projects.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only encryption and ownership configuration.
PROVIDER_ENCRYPTION_KEY=
PLATFORM_OWNER_EMAILS=owner@example.com
ALLOW_PRIVATE_PROVIDER_URLS=false
MAX_UPLOAD_BYTES=104857600
PASSWORD_AUTH_ENABLED=false
NEXT_PUBLIC_PASSWORD_AUTH_ENABLED=false
ALLOWED_ORIGINS=https://moatazalalqami.online

# Runtime capabilities. Chat remains disabled until a provider, credential and model are configured.
AI_CHAT_ENABLED=false
FILE_UPLOADS_ENABLED=true
CONTENT_EDITOR_ENABLED=true
TELEGRAM_INTEGRATION_ENABLED=false
SCHEDULED_PUBLISHING_ENABLED=false
